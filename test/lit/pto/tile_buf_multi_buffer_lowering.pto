// RUN: ptoas --mlir-print-ir-after=pto-view-to-memref %s 2>&1 1>/dev/null | FileCheck %s
// RUN: ptoas --mlir-print-ir-after=pto-plan-memory %s 2>&1 1>/dev/null | FileCheck %s --check-prefix=PLAN

module {
  func.func @tile_buf_type_multi_buffer() {
    %tile = pto.alloc_tile
        : !pto.tile_buf<vec, 16x16xf16, multi_buffer=2>
    return
  }

  func.func @alloc_tile_attr_multi_buffer() {
    %tile = pto.alloc_tile {pto.multi_buffer = 3 : i64}
        : !pto.tile_buf<vec, 16x16xf16>
    return
  }

  func.func @legacy_tile_buf_type_multi_buffer() {
    %tile = pto.alloc_tile
        : !pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=16, v_row=16,
                        v_col=16, blayout=row_major, slayout=none_box,
                        fractal=512, pad=0, multi_buffer=4>
    return
  }

  func.func @tile_buf_plan_memory_multi_buffer() {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c4 = arith.constant 4 : index
    scf.for %i = %c0 to %c4 step %c1 {
      %lhs = pto.alloc_tile : !pto.tile_buf<vec, 16x16xf32>
      %rhs = pto.alloc_tile : !pto.tile_buf<vec, 16x16xf32>
      %dst = pto.alloc_tile : !pto.tile_buf<vec, 16x16xf32, multi_buffer=2>
      pto.tadd ins(%lhs, %rhs
          : !pto.tile_buf<vec, 16x16xf32>,
            !pto.tile_buf<vec, 16x16xf32>)
        outs(%dst : !pto.tile_buf<vec, 16x16xf32, multi_buffer=2>)
    }
    return
  }
}

// CHECK: IR Dump After PTOViewToMemref
// CHECK-LABEL: func.func @tile_buf_type_multi_buffer
// CHECK: memref.alloc() {pto.multi_buffer = 2 : i32}
// CHECK-LABEL: func.func @alloc_tile_attr_multi_buffer
// CHECK: memref.alloc() {pto.multi_buffer = 3 : i32}
// CHECK-LABEL: func.func @legacy_tile_buf_type_multi_buffer
// CHECK: memref.alloc() {pto.multi_buffer = 4 : i32}

// PLAN: IR Dump After PlanMemory
// PLAN-LABEL: func.func @tile_buf_plan_memory_multi_buffer
// PLAN: pto.pointer_cast(%{{.*}}, %{{.*}}) {{.*}} : memref<16x16xf32
